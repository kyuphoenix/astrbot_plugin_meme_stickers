{
  "quote_reply": {
    "description": "是否引用触发消息",
    "type": "bool",
    "default": true
  },
  "interactive_preview_image_format": {
    "description": "交互生成过程中图片格式",
    "type": "string",
    "default": "jpeg",
    "options": ["png", "jpeg", "webp"]
  },
  "final_sticker_image_format": {
    "description": "最终生成贴纸格式",
    "type": "string",
    "default": "png",
    "options": ["png", "jpeg", "webp"]
  },
  "non_png_quality": {
    "description": "非 PNG 格式图片质量",
    "type": "int",
    "default": 95,
    "slider": {
      "min": 1,
      "max": 100,
      "step": 1
    }
  },
  "proxy": {
    "description": "网络请求代理地址",
    "type": "string",
    "default": ""
  },
  "github_url_template": {
    "description": "GitHub Raw 下载地址模板",
    "type": "string",
    "default": "https://raw.githubusercontent.com/{owner}/{repo}/{ref_path}/{path}"
  },
  "hub_manifest_url": {
    "description": "贴纸 Hub 清单地址",
    "type": "string",
    "default": "https://raw.githubusercontent.com/lgc-NB2Dev/meme-stickers-hub/main/manifest.json"
  },
  "retry_times": {
    "description": "请求重试次数",
    "type": "int",
    "default": 3
  },
  "req_concurrency": {
    "description": "并发请求数量",
    "type": "int",
    "default": 8
  },
  "req_timeout": {
    "description": "请求超时时间（秒）",
    "type": "int",
    "default": 5
  }
}
